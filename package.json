{
  "name": "weftwise",
  "version": "0.15.2",
  "private": true,
  "scripts": {
    "prepare": "git config core.hooksPath .githooks || true",
    "dev": "next dev",
    "dev:all": "concurrently --names next,worker --prefix-colors blue,green \"next dev\" \"node --env-file-if-exists=.env --env-file-if-exists=.env.local --import tsx src/server/worker-entry.ts\"",
    "build": "next build",
    "start": "next start",
    "start:all": "concurrently --names next,worker --prefix-colors blue,green \"next start\" \"node --env-file-if-exists=.env --env-file-if-exists=.env.local --import tsx src/server/worker-entry.ts\"",
    "lint": "next lint",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:migrate-subjects": "tsx scripts/migrate-introduce-subject.ts",
    "db:rebuild": "tsx scripts/rebuild-cache.ts",
    "eval:retrieval": "tsx scripts/eval-retrieval.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^2.0.85",
    "@ai-sdk/deepseek": "^1.0.45",
    "@ai-sdk/google": "^2.0.78",
    "@ai-sdk/mistral": "^2.0.36",
    "@ai-sdk/openai": "^2.0.110",
    "@ai-sdk/openai-compatible": "^1.0.42",
    "@ai-sdk/xai": "^2.0.76",
    "@tanstack/react-query": "^5.0.0",
    "@uiw/react-markdown-preview": "^5.2.0",
    "@uiw/react-md-editor": "^4.1.0",
    "adm-zip": "^0.6.0",
    "ai": "^5.0.210",
    "better-sqlite3": "^12.9.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "cytoscape": "^3.30.0",
    "drizzle-orm": "^0.38.0",
    "gpt-tokenizer": "^3.4.0",
    "gray-matter": "^4.0.3",
    "katex": "^0.16.47",
    "lucide-react": "^1.8.0",
    "mermaid": "^11.15.0",
    "next": "^15.0.0",
    "pdf-parse": "^1.1.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "rehype-katex": "^7.0.1",
    "rehype-pretty-code": "^0.14.0",
    "rehype-react": "^8.0.0",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.0.0",
    "simple-git": "^3.27.0",
    "tailwind-merge": "^3.5.0",
    "turndown": "^7.2.0",
    "unified": "^11.0.0",
    "zod": "^3.23.0",
    "zod-from-json-schema": "^0.0.5",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^20",
    "@types/pdf-parse": "^1.1.4",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/turndown": "^5.0.5",
    "autoprefixer": "^10",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.29.0",
    "eslint": "^9",
    "eslint-config-next": "^15.0.0",
    "postcss": "^8",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5",
    "vitest": "^2.1.9"
  }
}
