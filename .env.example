VAULT_PATH=./data/vault
DATABASE_PATH=./data/wiki.db

# --- LLM API Keys ---
# Model selection, base URLs, and parameters are configured in llm-config.json
# Only API keys belong here (referenced by "apiKeyEnv" in llm-config.json)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
DEEPSEEK_API_KEY=
MISTRAL_API_KEY=
XAI_API_KEY=
CUSTOM_LLM_API_KEY=

# --- Wiki Configuration ---
# Optional: set to require API key authentication on mutation endpoints
# When empty, all requests are allowed (suitable for local/dev use)
WIKI_API_KEY=
