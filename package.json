{
  "name": "agentic-wiki",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:all": "concurrently --names next,worker --prefix-colors blue,green \"next dev\" \"node --env-file-if-exists=.env --env-file-if-exists=.env.local --import tsx src/server/worker-entry.ts\"",
    "build": "next build",
    "start": "next start",
    "start:all": "concurrently --names next,worker --prefix-colors blue,green \"next start\" \"node --env-file-if-exists=.env --env-file-if-exists=.env.local --import tsx src/server/worker-entry.ts\"",
    "lint": "next lint",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:migrate-subjects": "tsx scripts/migrate-introduce-subject.ts"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^1.0.0",
    "@ai-sdk/deepseek": "^0.2.16",
    "@ai-sdk/google": "^1.2.22",
    "@ai-sdk/mistral": "^1.2.8",
    "@ai-sdk/openai": "^1.0.0",
    "@ai-sdk/openai-compatible": "^0.2.16",
    "@ai-sdk/xai": "^1.2.18",
    "@tanstack/react-query": "^5.0.0",
    "@uiw/react-markdown-preview": "^5.2.0",
    "@uiw/react-md-editor": "^4.1.0",
    "ai": "^4.0.0",
    "better-sqlite3": "^11.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "cytoscape": "^3.30.0",
    "drizzle-orm": "^0.38.0",
    "gray-matter": "^4.0.3",
    "lucide-react": "^1.8.0",
    "next": "^15.0.0",
    "pdf-parse": "^1.1.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "rehype-pretty-code": "^0.14.0",
    "rehype-react": "^8.0.0",
    "remark-frontmatter": "^5.0.0",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.0.0",
    "simple-git": "^3.27.0",
    "tailwind-merge": "^3.5.0",
    "turndown": "^7.2.0",
    "unified": "^11.0.0",
    "zod": "^3.23.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^20",
    "@types/pdf-parse": "^1.1.4",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/turndown": "^5.0.5",
    "autoprefixer": "^10",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.29.0",
    "eslint": "^9",
    "eslint-config-next": "^15.0.0",
    "postcss": "^8",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5"
  }
}
