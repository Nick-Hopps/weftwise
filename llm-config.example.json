{
  "$schema": "./llm-config.schema.json",
  "version": 1,
  "defaults": {
    "profile": "deepseek-default",
    "model": "deepseek-v4-pro",
    "maxTokens": 8192,
    "timeoutMs": 1200000,
    "maxRetries": 2
  },
  "tasks": {
    "query": {
      "profile": "deepseek-default",
      "model": "deepseek-v4-pro",
      "maxTokens": 32768
    },
    "lint": {
      "profile": "openai-default",
      "model": "gpt-5.6-terra",
      "maxTokens": 32768
    },
    "merge": {
      "profile": "anthropic-default",
      "model": "claude-sonnet-5",
      "maxTokens": 32768
    },
    "split": {
      "profile": "anthropic-default",
      "model": "claude-opus-4-8",
      "maxTokens": 65536
    },
    "curate": {
      "profile": "anthropic-default",
      "model": "claude-opus-4-8",
      "maxTokens": 32768
    },
    "fix": {
      "profile": "anthropic-default",
      "model": "claude-sonnet-5",
      "maxTokens": 32768
    },
    "embedding": {
      "profile": "openai-default",
      "model": "text-embedding-3-large"
    },
    "research:queries": {
      "profile": "deepseek-default",
      "model": "deepseek-v4-flash",
      "maxTokens": 2048
    },
    "research:triage": {
      "profile": "deepseek-default",
      "model": "deepseek-v4-flash",
      "maxTokens": 8192
    },
    "ingest:planner": {
      "profile": "anthropic-default",
      "model": "claude-opus-4-8",
      "maxTokens": 32768
    },
    "ingest:chunk-summarizer": {
      "profile": "deepseek-default",
      "model": "deepseek-v4-flash",
      "maxTokens": 512
    },
    "ingest:writer": {
      "profile": "anthropic-default",
      "model": "claude-sonnet-5",
      "maxTokens": 65536
    },
    "ingest:enricher": {
      "profile": "anthropic-default",
      "model": "claude-sonnet-5",
      "maxTokens": 65536
    },
    "ingest:image": {
      "profile": "google-default",
      "model": "gemini-3.1-flash-image",
      "maxTokens": 4096,
      "temperature": 0.2,
      "providerOptions": {
        "google": {
          "responseModalities": ["IMAGE"],
          "imageConfig": { "imageSize": "1K" }
        }
      }
    },
    "ingest:verifier-triage": {
      "profile": "deepseek-default",
      "model": "deepseek-v4-flash",
      "maxTokens": 8192
    },
    "ingest:verifier": {
      "profile": "deepseek-default",
      "model": "deepseek-v4-pro",
      "maxTokens": 65536
    },
    "ingest:verifier-apply": {
      "profile": "anthropic-default",
      "model": "claude-sonnet-5",
      "maxTokens": 65536
    },
    "reenrich:supplement": {
      "profile": "anthropic-default",
      "model": "claude-sonnet-5",
      "maxTokens": 65536
    },
    "reshape:page": {
      "profile": "anthropic-default",
      "model": "claude-sonnet-5",
      "maxTokens": 65536
    }
  },
  "providers": {
    "anthropic-default": {
      "provider": "anthropic",
      "apiKeyEnv": "ANTHROPIC_API_KEY"
    },
    "openai-default": {
      "provider": "openai",
      "apiKeyEnv": "OPENAI_API_KEY"
    },
    "google-default": {
      "provider": "google",
      "apiKeyEnv": "GOOGLE_API_KEY"
    },
    "deepseek-default": {
      "provider": "deepseek",
      "apiKeyEnv": "DEEPSEEK_API_KEY"
    },
    "mistral-default": {
      "provider": "mistral",
      "apiKeyEnv": "MISTRAL_API_KEY"
    },
    "xai-default": {
      "provider": "xai",
      "apiKeyEnv": "XAI_API_KEY"
    },
    "ollama-local": {
      "provider": "ollama",
      "baseURL": "http://localhost:11434"
    },
    "custom-compatible": {
      "provider": "openai-compatible",
      "name": "custom",
      "apiKeyEnv": "CUSTOM_LLM_API_KEY",
      "baseURL": "https://api.example.com/v1"
    }
  }
}
